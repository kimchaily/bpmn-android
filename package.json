{
  "name": "bpmn-mobile",
  "version": "1.0.0",
  "description": "A BPMN viewer/editor/simulator Android app built from the Obsidian BPMN plugin's bpmn-js core.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "sync": "cap sync",
    "add:android": "cap add android",
    "open:android": "cap open android",
    "apk:debug": "npm run build && (cap add android || cap sync android) && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@bpmn-io/properties-panel": "^3.34.0",
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.3",
    "@capacitor/share": "^6.0.3",
    "@capawesome/capacitor-file-picker": "^6.2.0",
    "bpmn-js": "^18.18.0",
    "bpmn-js-color-picker": "^0.7.2",
    "bpmn-js-create-append-anything": "^1.2.0",
    "bpmn-js-properties-panel": "^5.43.0",
    "bpmn-js-token-simulation": "^0.39.3",
    "diagram-js-grid": "^1.1.0",
    "diagram-js-minimap": "^5.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "vite": "^5.4.10"
  }
}
